# ── Grupos do WhatsApp ──────────────────────────────────────────────────────
# IDs separados por vírgula (ex: 123456789@g.us,987654321@g.us)
# Use !id no grupo pra descobrir o ID depois de ligar o bot
WHATSAPP_GROUP_IDS=
SOURCE_GROUP_IDS=

# ── Scheduler ────────────────────────────────────────────────────────────────
FETCH_INTERVAL_MIN=60
SEND_INTERVAL_MIN=5
DAILY_MSG_CAP=15
SPECIAL_DAY_MSG_CAP=25
QUIET_HOUR_START=0
QUIET_HOUR_END=6

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# ── Amazon Associates (opcional) ─────────────────────────────────────────────
# Cadastro: https://associados.amazon.com.br
# PA-API só ativa após 3 vendas
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# ── Shopee Afiliados (opcional) ───────────────────────────────────────────────
# Cadastro: https://affiliate.shopee.com.br
SHOPEE_APP_ID=
SHOPEE_SECRET=
SHOPEE_AFFILIATE_ID=

# ── MercadoLivre Afiliados (opcional) ────────────────────────────────────────
# Cadastro: https://www.mercadolivre.com.br/afiliados
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_AFFILIATE_TAG=
ML_AFFILIATE_TOOL=
